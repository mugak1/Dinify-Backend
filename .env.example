# Django core
SECRET_KEY=change-me-to-a-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ENV=dev

# CORS — in development set CORS_ORIGIN_ALLOW_ALL=True
# In production, list origins explicitly in CORS_ALLOWED_ORIGINS
CORS_ORIGIN_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=

# JWT token lifetimes
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=1

# Database
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=dinify
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Email
EMAIL_HOST=
EMAIL_ACCOUNT=
EMAIL_PASSWORD=
EMAIL_PORT=587
